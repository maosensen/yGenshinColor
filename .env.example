# Copy to .env.local and adjust as needed.
# Every variable here is validated by the zod schema in src/lib/env.ts —
# add new variables there first, then document them here.

# Logging (server-only)
# Levels: trace | debug | info | warn | error | fatal
# Default: debug in dev, info in prod
LOG_LEVEL=debug

# Public site URL (used for absolute links, metadata, etc.)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
